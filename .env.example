# Local development — use a credentials file (not committed to git)
PORT=8000
GOOGLE_SHEETS_ID=your-spreadsheet-id
GOOGLE_SHEET_NAME=Sheet1
GOOGLE_CREDENTIALS_FILE=./google-credentials.json

# Render / production — use base64 (recommended; raw JSON often gets truncated on Render):
#   base64 -i google-credentials.json | tr -d '\n'
# GOOGLE_CREDENTIALS_JSON_B64=ewogICJ0eXBlIjogInNlcnZpY2VfYWNjb3VudCIsLi4u
