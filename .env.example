# Local development — use a credentials file (not committed to git)
PORT=8000
GOOGLE_SHEETS_ID=your-spreadsheet-id
GOOGLE_SHEET_NAME=Sheet1
GOOGLE_CREDENTIALS_FILE=./google-credentials.json

# Render / production — set GOOGLE_CREDENTIALS_JSON instead of GOOGLE_CREDENTIALS_FILE.
# Paste the entire google-credentials.json contents as a single-line value in the Render dashboard.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",...}
